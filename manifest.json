{
  "manifest_version": 3,
  "name": "GitHub Actions Collapse",
  "version": "1.0.1",
  "description": "Auto-collapse jobs in GitHub Actions runs with manual override",
  "permissions": ["storage"],
  "host_permissions": ["*://github.com/*/actions/runs/*"],
  "content_scripts": [{
    "matches": ["*://github.com/*/actions/runs/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_title": "Toggle Collapse",
    "default_icon": {
      "48": "icons/active-48.svg",
      "96": "icons/active-96.svg",
      "128": "icons/active-128.svg"
    }
  },
  "icons": {
    "48": "icons/active-48.svg",
    "96": "icons/active-96.svg",
    "128": "icons/active-128.svg"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "gh-actions-collapse@local",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "collects_data": false,
        "required": ["none"]
      }
    }
  }
}
